# Native defaults bind only to localhost. Docker Compose overrides host/data paths.
API_HOST=127.0.0.1
API_PORT=8000
WEB_PORT=3000
LOCAL_UID=1000
LOCAL_GID=1000
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/app.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

MAX_CLIP_DURATION_SECONDS=1800
DOWNLOAD_MARGIN_SECONDS=5
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
YTDLP_PATH=yt-dlp
VIDEO_CRF=22
VIDEO_PRESET=fast

SILENCE_MIN_SECONDS=1.2
SILENCE_REMOVE_AFTER_SECONDS=2.5
SILENCE_PADDING_SECONDS=0.2

WHISPER_MODEL=small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_LANGUAGE=auto

# Automatic VOD Analysis. Phase 2 samples signals; Phase 3 derives cached phase labels.
VOD_ANALYSIS_FIXTURE_MODE=false
VOD_ANALYSIS_PIPELINE_VERSION=vod-analysis-v2-coarse.1
VOD_ANALYSIS_PHASE_PIPELINE_VERSION=vod-analysis-profile-layout.2
VOD_ANALYSIS_MINIMUM_CANDIDATE_SCORE=55
VOD_ANALYSIS_DEBUG=false
VALIDATION_DEBUG=false
LAYOUT_SAMPLE_SECONDS=2
LAYOUT_TRANSITION_CONFIRMATION=3
VISUAL_LAYOUT_PROFILE_PATH=./data/profiles/illojuan_visual.json
VOD_ANALYSIS_WINDOW_SECONDS=30
VOD_ANALYSIS_AUDIO_SAMPLE_SECONDS=10
VOD_ANALYSIS_VISUAL_SAMPLES_PER_WINDOW=2
VOD_ANALYSIS_FETCH_BLOCK_SECONDS=900
VOD_ANALYSIS_MAX_SECONDS=10800
VOD_ANALYSIS_PROBE_MODEL=tiny
VOD_ANALYSIS_PROBE_VOICE_RATIO=0.20
VOD_ANALYSIS_PROBE_MIN_SPEECH_SECONDS=2.0
VOD_ANALYSIS_SAMPLE_TIMEOUT_SECONDS=90

# Smart Vertical Layout (used only for vertical jobs with the option enabled).
SMART_VERTICAL_LAYOUT_DEFAULT=true
SCENE_DETECTION_ENABLED=true
SCENE_CHANGE_THRESHOLD=0.08
SCENE_MIN_DURATION_SECONDS=1.5
SCENE_SAMPLE_FPS=2
FACE_DETECTION_SAMPLE_FPS=2
FACE_ANALYSIS_MAX_WIDTH=1280
FACE_DETECTOR_MODEL_PATH=./data/models/face_detection/face_detection_yunet_2023mar.onnx
FACE_DETECTOR_SCORE_THRESHOLD=0.55
FACE_DETECTOR_PROFILE_THRESHOLD=0.40
FACE_DETECTOR_NMS_THRESHOLD=0.30
FACE_DETECTOR_TOP_K=5000
FACE_DETECTOR_HAAR_FALLBACK=true
FACE_LAYOUT_MIN_CONFIDENCE=0.60
FULLSCREEN_FACE_AREA_THRESHOLD=0.025
FACECAM_MAX_FACE_AREA_THRESHOLD=0.06
FACE_STABILITY_POSITION_TOLERANCE=0.04
FACE_STABILITY_SIZE_TOLERANCE=0.20
LAYOUT_MIN_SEGMENT_SECONDS=1.5
LAYOUT_MERGE_IOU_THRESHOLD=0.70
LAYOUT_MERGE_CENTER_DISTANCE_RATIO=0.05
FACEBOX_EXPAND_LEFT=0.80
FACEBOX_EXPAND_RIGHT=0.80
FACEBOX_EXPAND_TOP=0.55
FACEBOX_EXPAND_BOTTOM=1.60
VERTICAL_FACECAM_HEIGHT_RATIO=0.38
VERTICAL_OUTPUT_WIDTH=1080
VERTICAL_OUTPUT_HEIGHT=1920
VERTICAL_DIVIDER_HEIGHT=4
SMART_LAYOUT_DEBUG=false

YOUTUBE_CLIENT_SECRETS_PATH=./data/credentials/client_secret.json
YOUTUBE_TOKEN_PATH=./data/credentials/token.json
TWITCH_COOKIES_PATH=./data/credentials/twitch_cookies.txt
DEMO_MODE=false
LOG_LEVEL=INFO
